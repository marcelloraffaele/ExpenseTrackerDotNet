@page
@model IndexModel
@{
    ViewData["Title"] = "Expense Tracker";
    var totalCategoryAmount = Model.CategorySummaries.Sum(c => c.Total);
}

<div class="dashboard-header mb-4">
    <h1 class="display-5 fw-bold">
        <span class="text-primary">💰</span> Expense Tracker
    </h1>
    <p class="text-muted">Track your daily expenses and visualize your spending patterns.</p>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Summary Row -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 summary-card">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="summary-icon bg-primary-subtle rounded-circle d-flex align-items-center justify-content-center">
                    <span class="fs-3">📅</span>
                </div>
                <div>
                    <div class="text-muted small fw-semibold text-uppercase">This Month</div>
                    @if (Model.MonthlyTotal != null)
                    {
                        <div class="fs-4 fw-bold text-primary">
                            $@Model.MonthlyTotal.Total.ToString("N2")
                        </div>
                        <div class="text-muted small">
                            @(System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(Model.MonthlyTotal.Month))
                            @Model.MonthlyTotal.Year
                        </div>
                    }
                    else
                    {
                        <div class="fs-4 fw-bold text-primary">$0.00</div>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 summary-card">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="summary-icon bg-success-subtle rounded-circle d-flex align-items-center justify-content-center">
                    <span class="fs-3">📋</span>
                </div>
                <div>
                    <div class="text-muted small fw-semibold text-uppercase">Total Expenses</div>
                    <div class="fs-4 fw-bold text-success">@Model.Expenses.Count</div>
                    <div class="text-muted small">records tracked</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 summary-card">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="summary-icon bg-warning-subtle rounded-circle d-flex align-items-center justify-content-center">
                    <span class="fs-3">🏷️</span>
                </div>
                <div>
                    <div class="text-muted small fw-semibold text-uppercase">Categories Used</div>
                    <div class="fs-4 fw-bold text-warning">@Model.CategorySummaries.Count</div>
                    <div class="text-muted small">of @Model.Categories.Count available</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Left Column: Add Expense Form + Expense List -->
    <div class="col-lg-7">
        <!-- Add Expense Form -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-primary text-white fw-semibold">
                ➕ Add New Expense
            </div>
            <div class="card-body">
                <form method="post" asp-page-handler="AddExpense">
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <label asp-for="NewExpense.Amount" class="form-label fw-semibold">Amount ($)</label>
                            <input asp-for="NewExpense.Amount" type="number" step="0.01" min="0.01"
                                   class="form-control" placeholder="0.00" required />
                            <span asp-validation-for="NewExpense.Amount" class="text-danger small"></span>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="NewExpense.Category" class="form-label fw-semibold">Category</label>
                            <select asp-for="NewExpense.Category" class="form-select" required>
                                <option value="">-- Select category --</option>
                                @foreach (var cat in Model.Categories)
                                {
                                    <option value="@cat">@cat</option>
                                }
                            </select>
                            <span asp-validation-for="NewExpense.Category" class="text-danger small"></span>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="NewExpense.Date" class="form-label fw-semibold">Date</label>
                            <input asp-for="NewExpense.Date" type="date" class="form-control"
                                   value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="NewExpense.Description" class="form-label fw-semibold">Description</label>
                            <input asp-for="NewExpense.Description" type="text" class="form-control"
                                   placeholder="Brief description" />
                        </div>
                    </div>
                    <div class="mt-3 d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary px-4">
                            Add Expense
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Expense List -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
                <span>📄 All Expenses</span>
                <span class="badge bg-secondary">@Model.Expenses.Count</span>
            </div>
            <div class="card-body p-0">
                @if (Model.Expenses.Count == 0)
                {
                    <div class="text-center text-muted py-5">
                        <div class="fs-1">💸</div>
                        <p>No expenses recorded yet. Add your first one!</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Date</th>
                                    <th>Category</th>
                                    <th>Description</th>
                                    <th class="text-end">Amount</th>
                                    <th class="text-center">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var expense in Model.Expenses.OrderByDescending(e => e.Date))
                                {
                                    <tr>
                                        <td class="text-nowrap">@expense.Date.ToString("MMM dd, yyyy")</td>
                                        <td>
                                            <span class="badge category-badge">@expense.Category</span>
                                        </td>
                                        <td class="text-truncate-cell">@expense.Description</td>
                                        <td class="text-end fw-semibold text-danger">
                                            $@expense.Amount.ToString("N2")
                                        </td>
                                        <td class="text-center">
                                            <form method="post" asp-page-handler="DeleteExpense"
                                                  asp-route-id="@expense.Id"
                                                  onsubmit="return confirm('Delete this expense?')">
                                                <button type="submit" class="btn btn-outline-danger btn-sm">
                                                    🗑
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td colspan="3" class="fw-bold">Total</td>
                                    <td class="text-end fw-bold text-danger">
                                        $@Model.Expenses.Sum(e => e.Amount).ToString("N2")
                                    </td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Right Column: Monthly Summary + Category Chart -->
    <div class="col-lg-5">
        <!-- Monthly Spending Card -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white fw-semibold">
                📊 Spending by Category
            </div>
            <div class="card-body">
                @if (Model.CategorySummaries.Count == 0)
                {
                    <div class="text-center text-muted py-3">
                        <p>No spending data available.</p>
                    </div>
                }
                else
                {
                    <!-- Chart.js Doughnut Chart -->
                    <div class="chart-container mb-4">
                        <canvas id="categoryChart"></canvas>
                    </div>

                    <!-- CSS progress bars breakdown -->
                    <div class="category-breakdown">
                        @foreach (var summary in Model.CategorySummaries.OrderByDescending(c => c.Total))
                        {
                            var percentage = totalCategoryAmount > 0
                                ? (summary.Total / totalCategoryAmount) * 100
                                : 0;
                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="fw-semibold small">@summary.Category</span>
                                    <span class="text-muted small">
                                        $@summary.Total.ToString("N2")
                                        <span class="text-muted">&nbsp;(@percentage.ToString("N1")%)</span>
                                    </span>
                                </div>
                                <div class="progress" style="height: 8px;">
                                    <div class="progress-bar" role="progressbar"
                                         style="width: @percentage.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%"
                                         aria-valuenow="@percentage.ToString("F1")"
                                         aria-valuemin="0" aria-valuemax="100">
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Recent Activity card -->
        @if (Model.Expenses.Count > 0)
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold">
                    🕐 Recent Activity
                </div>
                <div class="list-group list-group-flush">
                    @foreach (var expense in Model.Expenses.OrderByDescending(e => e.Date).Take(5))
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <div class="fw-semibold small">@expense.Description</div>
                                <div class="text-muted small">
                                    <span class="badge category-badge me-1">@expense.Category</span>
                                    @expense.Date.ToString("MMM dd")
                                </div>
                            </div>
                            <span class="fw-bold text-danger">$@expense.Amount.ToString("N2")</span>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            @if (Model.CategorySummaries.Count > 0)
            {
                var labels = Model.CategorySummaries.OrderByDescending(c => c.Total).Select(c => c.Category).ToList();
                var data = Model.CategorySummaries.OrderByDescending(c => c.Total).Select(c => c.Total).ToList();
                <text>
                const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(labels));
                const data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(data));
                const palette = [
                    '#4F81BD','#C0504D','#9BBB59','#8064A2','#4BACC6',
                    '#F79646','#2C4770','#7B1826','#4F6228','#17375E'
                ];
                const colors = labels.map((_, i) => palette[i % palette.length]);

                const ctx = document.getElementById('categoryChart');
                if (ctx) {
                    new Chart(ctx, {
                        type: 'doughnut',
                        data: {
                            labels: labels,
                            datasets: [{
                                data: data,
                                backgroundColor: colors,
                                borderWidth: 2,
                                borderColor: '#fff'
                            }]
                        },
                        options: {
                            responsive: true,
                            plugins: {
                                legend: {
                                    position: 'bottom',
                                    labels: { padding: 12, font: { size: 12 } }
                                },
                                tooltip: {
                                    callbacks: {
                                        label: function (ctx) {
                                            return ' $' + ctx.parsed.toFixed(2);
                                        }
                                    }
                                }
                            }
                        }
                    });
                }
                </text>
            }
        })();
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
