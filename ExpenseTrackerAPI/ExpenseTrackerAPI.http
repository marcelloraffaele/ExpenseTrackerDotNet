@ExpenseTrackerAPI_HostAddress = http://localhost:5155

### OpenAPI specification
GET {{ExpenseTrackerAPI_HostAddress}}/openapi/v1.json
Accept: application/json

###

### Get all available categories
GET {{ExpenseTrackerAPI_HostAddress}}/api/expenses/categories
Accept: application/json

###

### Get all expenses
GET {{ExpenseTrackerAPI_HostAddress}}/api/expenses
Accept: application/json

###

### Add a new expense (with default current date)
POST {{ExpenseTrackerAPI_HostAddress}}/api/expenses
Content-Type: application/json

{
  "amount": 25.50,
  "category": "Food",
  "description": "Lunch at the office canteen"
}

###

### Add a new expense (with a manual date)
POST {{ExpenseTrackerAPI_HostAddress}}/api/expenses
Content-Type: application/json

{
  "amount": 60.00,
  "category": "Transport",
  "date": "2025-02-20T08:00:00Z",
  "description": "Monthly bus pass"
}

###

### Add a new expense - Entertainment
POST {{ExpenseTrackerAPI_HostAddress}}/api/expenses
Content-Type: application/json

{
  "amount": 14.99,
  "category": "Entertainment",
  "description": "Streaming service subscription"
}

###

### Add a new expense - Bills
POST {{ExpenseTrackerAPI_HostAddress}}/api/expenses
Content-Type: application/json

{
  "amount": 120.00,
  "category": "Bills",
  "description": "Electricity bill"
}

###

### Get total spending for the current month
GET {{ExpenseTrackerAPI_HostAddress}}/api/expenses/summary/monthly
Accept: application/json

###

### Get spending breakdown by category
GET {{ExpenseTrackerAPI_HostAddress}}/api/expenses/summary/categories
Accept: application/json

###

### Delete an expense by ID (replace the guid with a real one)
DELETE {{ExpenseTrackerAPI_HostAddress}}/api/expenses/00000000-0000-0000-0000-000000000000

###
